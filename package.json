{
  "name": "cortex",
  "version": "0.1.0",
  "description": "Universal AI Brain \u00e2\u20ac\u201d multi-transport memory daemon for Claude Code, Gemini CLI, Codex, Cursor, and local LLMs",
  "main": "daemon-rs/target/release/cortex.exe",
  "bin": {
    "cortex": "src/cli.js"
  },
  "scripts": {
    "build": "cd daemon-rs && cargo build --release",
    "test": "cd daemon-rs && cargo test",
    "desktop:install": "npm --prefix desktop/cortex-control-center install",
    "desktop:dev": "npm --prefix desktop/cortex-control-center run dev",
    "desktop:build": "npm --prefix desktop/cortex-control-center run build"
  },
  "keywords": [
    "ai",
    "memory",
    "brain",
    "mcp",
    "cortex"
  ],
  "license": "MIT",
  "dependencies": {
    "sql.js": "^1.11.0"
  }
}